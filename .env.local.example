# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used to build absolute redirect URLs for OAuth (no trailing slash).
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (Vercel): set to your deployed URL, e.g.
# NEXT_PUBLIC_SITE_URL=https://fraylit.vercel.app
